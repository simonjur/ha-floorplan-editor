{
  "name": "floorplan-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Home Assistant floor plan editor card — draw rooms, bind entities, live state overlay.",
  "scripts": {
    "dev": "python3 -m http.server 8934 --directory src",
    "dev:card": "python3 -m http.server 8935",
    "build": "esbuild src/floorplan-card.js --bundle --format=esm --outfile=dist/floorplan-card.js",
    "test": "node --test test/*.test.js",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.56.0",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1"
  }
}
